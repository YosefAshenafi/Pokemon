{
  "expo": {
    "name": "Pokemon",
    "slug": "pokedex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "pokedex",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.jossyfreelancer.pokedex"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D50C8",
        "foregroundImage": "./assets/images/android-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2D50C8",
          "image": "./assets/images/logo-mark.png",
          "imageWidth": 140
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
